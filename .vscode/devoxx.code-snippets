      "                int newValue = rs.next() ? rs.getInt(1) : 0;",
      "                conn.commit();",
      "                return newValue;",
      "            }",
      "        }",
      "    } catch (SQLException e) {",
      "        conn.rollback();",
      "        throw e;",
      "    } finally {",
      "        conn.setAutoCommit(true);",
      "    }",
      "}"
